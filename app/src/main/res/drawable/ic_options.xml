<?xml version="1.0" encoding="utf-8"?>
<!--
    Phosphor SlidersHorizontal-ish (Regular weight). Three horizontal tracks
    with round thumbs at staggered positions, reading as "tune / options."
    Single-color compatible: thumbs are filled circles on top of stroked
    tracks, so the icon tints cleanly under Compose's Icon(tint = ...).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="256"
    android:viewportHeight="256">
    <!-- Three horizontal tracks -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="16"
        android:strokeLineCap="round"
        android:pathData="M40,80 L216,80 M40,128 L216,128 M40,176 L216,176" />
    <!-- Three thumbs (filled circles) at staggered positions -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M 84 60 a 20 20 0 1 0 0 40 a 20 20 0 1 0 0 -40 Z
                          M 172 108 a 20 20 0 1 0 0 40 a 20 20 0 1 0 0 -40 Z
                          M 100 156 a 20 20 0 1 0 0 40 a 20 20 0 1 0 0 -40 Z" />
</vector>
